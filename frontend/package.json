{
  "name": "@mopri/frontend",
  "version": "1.0.0",
  "description": "A web interface for the mobile app privacy analysis toolchain mopri, enabling users to upload applications, configure and run analyses, view detailed reports, and visualize findings.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "author": "Cornell Ziepel",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-brands-svg-icons": "^6.6.0",
    "@fortawesome/free-regular-svg-icons": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@matpool/vue-json-view": "^0.1.8",
    "@mopri/schema": "workspace:^",
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.0.5",
    "bootstrap": "^5.3.3",
    "d3": "^7.9.0",
    "dompurify": "^3.1.7",
    "jquery": "^3.7.1",
    "js-sha256": "^0.11.0",
    "ky": "^1.6.0",
    "marked": "^14.1.3",
    "pinia": "^2.2.2",
    "popper.js": "^1.16.1",
    "vue": "^3.4.29",
    "vue-json-view": "link:@types/@matpool/vue-json-view",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.8.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/bootstrap": "^5.2.10",
    "@types/geojson": "^7946.0.14",
    "@types/har-format": "^1.2.16",
    "@types/node": "^20.14.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "npm-run-all2": "^6.2.0",
    "prettier": "^3.2.5",
    "typescript": "~5.4.0",
    "vite": "^5.3.1",
    "vue-tsc": "^2.0.21"
  }
}
