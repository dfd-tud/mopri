    "testStaticExecuterExodus": "tsx ./src/modules/StaticAnalysis/StaticExecuterExodus.test.ts",
    "testNetworkRecordingPCAP": "tsx ./src/modules/DynamicAnalysis/collectors/dynamic/NetworkTrafficRecording/NetworkTrafficRecordingPCAP.test.ts",
    "testScreenRecording": "tsx ./src/modules/DynamicExecuter/DynamicCollectors/ScreenRecording.test.ts",
    "testDynamicEnrichment": "tsx ./src/modules/DynamicAnalysis/enrichment/NetworkTrafficEnrichmentManager.test.ts",
    "testDeviceDataCollection": "tsx ./src/modules/DynamicExecuter/DeviceDataCollector.test.ts",
    "testApkUpload": "tsx ./src/helpers/ApkHelper.test.ts",
    "testPCAPdroidDownloader": "tsx ./src/modules/DynamicAnalysis/collectors/dynamic/PCAPdroidDownloader.test.ts"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "18.20.8"
    }
  },
