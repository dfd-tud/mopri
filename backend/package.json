    "@types/har-format": "^1.2.16",
    "@types/node": "^20.14.2",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.1",
